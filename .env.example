# =============================================================================
# TrinaxAI — Environment Configuration Template
# =============================================================================
# Copy to .env and customize:  cp .env.example .env
# Complete reference: docs/ENVIRONMENT_VARIABLES.md
#
# Every variable is optional. TrinaxAI auto-detects your hardware (RAM)
# and applies sensible defaults. Only set what you need to override.
#
# Profile presets (set via TRINAXAI_PROFILE):
#   4gb   – Minimal, ~4 GB RAM, tiny context, 1 embed worker.
#   8gb   – Low-memory, ~8 GB RAM, 1B/1.5B models and lite embeddings.
#   16gb  – Balanced default for ~16 GB RAM.
#   max   – High-quality, 32 GB+ RAM, 7b deep model, bigger context.
#   ultra – 64 GB+ RAM + powerful GPU, 14b deep model, max context.
# =============================================================================

# ── Profile ────────────────────────────────────────────────────────────────
TRINAXAI_PROFILE=16gb
# Performance mode: fast | balanced | quality.
# fast keeps responses/indexing snappier; set quality for larger context retrieval.
TRINAXAI_PERFORMANCE_MODE=fast

# ── Network ────────────────────────────────────────────────────────────────
# Keep FastAPI behind the same-host PWA gateway. Expose only the PWA/VPN URL.
TRINAXAI_HOST=127.0.0.1
# Emergency compatibility escape hatch. Do not enable on shared/public networks.
#TRINAXAI_UNSAFE_BIND_BACKEND=0
TRINAXAI_PORT=3333
TRINAXAI_RAG_HTTPS=1
# Optional CA bundle for verified CLI HTTPS. Local mkcert/self-signed roots are
# discovered automatically when this is not set.
#TRINAXAI_CA_FILE=/path/to/rootCA.pem

# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434
#OLLAMA_HOST=127.0.0.1:11434

# ── Model Fleet (auto-router picks the best model per query) ───────────────
# Current Qwen 3.5 fleet; 16gb/Medium profile shown.
TRINAXAI_MODEL_GENERAL=qwen3.5:4b
TRINAXAI_MODEL_CODE=qwen3.5:4b
TRINAXAI_MODEL_DEEP=qwen3.5:4b
TRINAXAI_MODEL_FAST=qwen3.5:2b
# 8gb defaults if not overridden:
# TRINAXAI_MODEL_GENERAL=qwen3.5:2b
# TRINAXAI_MODEL_CODE=qwen3.5:2b
# TRINAXAI_MODEL_DEEP=qwen3.5:2b
# TRINAXAI_MODEL_FAST=qwen3.5:2b
# Max: qwen3.5:9b; Ultra: qwen3.5:35b + qwen3-coder:30b.

# Fallback when auto-router is off (TRINAXAI_AUTO_ROUTE=0).
#TRINAXAI_LLM=qwen3.5:4b
#TRINAXAI_LLM_HEAVY=qwen3.5:4b

# Set to "0" to disable the model auto-router.
#TRINAXAI_AUTO_ROUTE=1

# ── Embeddings ─────────────────────────────────────────────────────────────
# Preset: balanced | lite | fast
#   balanced – qwen3-embedding:0.6b, 1024 dims, multilingual.
#   lite     – nomic-embed-text, 768 dims, faster, English-leaning.
#   fast     – all-minilm, 384 dims, smallest, English-only.
#TRINAXAI_EMBED_PRESET=balanced
#TRINAXAI_EMBED=qwen3-embedding:0.6b
#TRINAXAI_EMBED_DIMS=1024

# ── Context & Threads ──────────────────────────────────────────────────────
# Token context window (auto-scaled by profile: 2048/4096/8192/16384).
#TRINAXAI_NUM_CTX=4096
# CPU threads per request (default 8 — balanced for concurrent embeddings).
#TRINAXAI_NUM_THREAD=8

# ── Generation pipeline (Phase 3–8: classifier + per-task decoding) ─────────
# The generation pipeline picks a regime (grounded_qa | code_gen | creative |
# explain) per request and tunes decoding accordingly. These override the
# auto-derived values; leave commented to keep the tuned defaults.
#
# Context window used for free-form generation (RAG off). Generation regimes
# get a larger window than the RAG default because no chunks are injected.
#TRINAXAI_GEN_NUM_CTX=8192
# Hard cap for auto-grown context on very long prompts.
#TRINAXAI_GEN_NUM_CTX_MAX=16384
# Force a fixed output token budget (otherwise reserved from num_ctx per task).
#TRINAXAI_GEN_NUM_PREDICT=3072
# Per-regime temperature overrides (regime name in UPPERCASE):
#TRINAXAI_GEN_TEMPERATURE_CODE_GEN=0.15
#TRINAXAI_GEN_TEMPERATURE_CREATIVE=0.5
#TRINAXAI_GEN_TEMPERATURE_EXPLAIN=0.4
#TRINAXAI_GEN_TEMPERATURE_GROUNDED_QA=0.0
# generate→validate→fix passes for complex code/creative tasks (0 disables).
#TRINAXAI_GEN_MAX_FIX=1


# ── Embedding Concurrency ──────────────────────────────────────────────────
# Workers sending concurrent embedding requests to Ollama.
#TRINAXAI_EMBED_WORKERS=2
# Embed batch size per Ollama call. Larger batches reduce per-request overhead.
# Defaults: 1 on low-memory profiles, 8 on 16gb/max, 16 on ultra.
#TRINAXAI_EMBED_BATCH=8

# ── Model Keep-Alive ───────────────────────────────────────────────────────
# LLM keep-alive. "0s" unloads chat/code models after each request.
# "30m" / "60m" = keep warm in RAM (faster, uses more RAM).
#TRINAXAI_KEEP_ALIVE=0s
# Embedding keep-alive is separate so indexing does not reload the embedder every batch.
# Use "0s" only when RAM is very tight.
#TRINAXAI_EMBED_KEEP_ALIVE=15m
# Request timeout in seconds.
#TRINAXAI_TIMEOUT=300

# ── Chunking ───────────────────────────────────────────────────────────────
# Prose chunk size in tokens (1024 default, 1536 for ultra).
#TRINAXAI_CHUNK_SIZE=1024
#TRINAXAI_CHUNK_OVERLAP=150
# Code chunking (AST-aware, respects function/class boundaries).
#TRINAXAI_CODE_CHUNK_LINES=60
#TRINAXAI_CODE_CHUNK_LINES_OVERLAP=12
#TRINAXAI_CODE_MAX_CHARS=2000

# ── Retrieval ──────────────────────────────────────────────────────────────
# Final chunks injected into the LLM prompt.
# Fast defaults: 3-6 by profile. Raise for broader answers.
#TRINAXAI_SIMILARITY_TOP_K=4
# Candidates each retriever (vector / BM25) contributes before fusion.
#TRINAXAI_FUSION_CANDIDATES=8
# Short cache for repeated RAG retrievals.
#TRINAXAI_RETRIEVAL_CACHE_SECONDS=20
# Short cache for Knowledge Browser source/chunk listings.
#TRINAXAI_SOURCES_CACHE_SECONDS=30
# Maximum LRU entries for distinct active-collection retriever combinations.
#TRINAXAI_RETRIEVER_CACHE_MAX_COMBINATIONS=32

# ── Web search (opt-in) ───────────────────────────────────────────────────
# auto: Brave when a key exists, then SearXNG, otherwise DuckDuckGo (no key).
# The PWA only searches when the globe button is active or the user explicitly
# asks TrinaxAI to search the internet.
#TRINAXAI_WEB_SEARCH_PROVIDER=auto
#TRINAXAI_BRAVE_SEARCH_API_KEY=
#TRINAXAI_SEARXNG_URL=http://127.0.0.1:8080
#TRINAXAI_WEB_SEARCH_TIMEOUT=15
#TRINAXAI_WEB_SEARCH_MAX_RESULTS=6
#TRINAXAI_WEB_SEARCH_CACHE_SECONDS=300

# ── Reranking (cross-encoder — big precision boost) ────────────────────────
# Enable with TRINAXAI_RERANK=1. Install deps: pip install -r requirements-rerank.txt
#TRINAXAI_RERANK=0
#TRINAXAI_RERANK_MODEL=BAAI/bge-reranker-v2-m3
#TRINAXAI_RERANK_TOP_N=5

# ── Indexing ───────────────────────────────────────────────────────────────
# Directory to index recursively (default: parent of the repo).
#TRINAXAI_INDEX_DIR=~/Documents
# Max file size to index, in bytes (default 3 MB).
#TRINAXAI_MAX_FILE_BYTES=3145728
# PDF, DOCX and PPTX use a higher limit because embedded media can make their
# container large even though TrinaxAI only extracts their readable text.
#TRINAXAI_DOCUMENT_MAX_FILE_BYTES=536870912
# Maximum retained chat attachment size (shared across devices on the LAN).
#TRINAXAI_CHAT_ATTACHMENT_MAX_BYTES=536870912
# Maximum total retained attachment storage and file count.
#TRINAXAI_CHAT_ATTACHMENTS_MAX_BYTES=4294967296
#TRINAXAI_CHAT_ATTACHMENTS_MAX_FILES=1000
# Max files per upload batch.
#TRINAXAI_UPLOAD_MAX_FILES=2500
# Max total upload size, in bytes (default 2 GiB).
#TRINAXAI_UPLOAD_MAX_BYTES=2147483648
# Max document size accepted for temporary chat extraction (default 128 MiB).
#TRINAXAI_DOC_EXTRACT_MAX_BYTES=134217728
# Collection to use for indexing/querying.
#TRINAXAI_COLLECTION_ID=default
#TRINAXAI_COLLECTION_NAME=General
# Append-only: never re-index existing files, only add new ones.
#TRINAXAI_INDEX_APPEND=0
# Files processed per indexing batch. Lower uses less RAM; higher can be faster.
#TRINAXAI_INDEX_BATCH_SIZE=100
# Seconds an index writer may wait for another writer to finish.
#TRINAXAI_INDEX_LOCK_TIMEOUT=3600
# Timeout used by `trinaxai index` while waiting for the indexer process.
#TRINAXAI_INDEX_TIMEOUT=3600
# Maximum silence within one indexing stage before the job fails explicitly.
#TRINAXAI_INDEX_STAGE_TIMEOUT=900
# Maximum chunks embedded in one bounded batch (backpressure / memory control).
#TRINAXAI_INDEX_NODE_BATCH_SIZE=32
# Watcher subprocess timeout and retained diagnostic-output limit. A timed-out
# indexer is terminated as a process group and the watcher remains available.
#TRINAXAI_WATCH_INDEX_TIMEOUT=1800
#TRINAXAI_WATCH_RELOAD_TIMEOUT=30
#TRINAXAI_WATCH_OUTPUT_MAX_BYTES=16384
# Stable identity for this independently synchronized source root. Normally
# derived from its canonical path; set only when the source must keep an ID
# after moving to another path.
#TRINAXAI_SOURCE_ID=

# ── Persistent memory ─────────────────────────────────────────────────────
# Quotas prevent accidental prompt/store growth while keeping memory local.
#TRINAXAI_MEMORY_MAX_ENTRIES=1000
#TRINAXAI_MEMORY_MAX_FILE_BYTES=4194304
#TRINAXAI_MEMORY_TEXT_MAX_CHARS=20000
#TRINAXAI_MEMORY_MAX_TAGS=50
#TRINAXAI_MEMORY_TAG_MAX_CHARS=100
#TRINAXAI_MEMORY_SUMMARY_MAX_CHARS=50000

# ── Concurrency ────────────────────────────────────────────────────────────
# Keep these at 1 on typical local hardware to avoid RAM/VRAM model thrashing.
#TRINAXAI_MODEL_MAX_CONCURRENCY=1
# Cross-process FastAPI/Vite inference queue. Both processes must point to the
# same lock directory when the default storage path is overridden.
#TRINAXAI_INFERENCE_LOCK_FILE=./storage/.inference.lock
#TRINAXAI_INFERENCE_QUEUE_TIMEOUT=600
#TRINAXAI_VOICE_MAX_CONCURRENCY=1
#TRINAXAI_DOCUMENT_MAX_CONCURRENCY=1

# ── Security ───────────────────────────────────────────────────────────────
# CORS allowed origins (comma-separated). Never use "*" on a LAN install.
TRINAXAI_CORS_ORIGINS=https://localhost:3334,http://localhost:3334
# Allow protected endpoints from a private LAN only when no admin token is
# configured. Once a token exists, every non-loopback request must provide it.
#TRINAXAI_ALLOW_LAN_SYSTEM=0
# Admin token for protected data and administration endpoints. The PWA keeps a
# pasted token in sessionStorage. Prefer pairing a device with least-privilege
# scopes instead of copying the administrator secret to it.
#TRINAXAI_ADMIN_TOKEN=
# Paired-device registry/secret. Defaults are private files in storage/; only
# move them when both FastAPI and the PWA gateway use the same paths.
#TRINAXAI_DEVICE_REGISTRY=./storage/device_pairing.json
#TRINAXAI_DEVICE_SECRET_FILE=./storage/.device_secret
# Packaged CLI bearer credential for a paired device (process environment only).
#TRINAXAI_DEVICE_TOKEN=
# Shared gateway/backend HMAC identity. Prefer the generated mode-0600 file;
# configure the raw secret only in process-managed secret storage.
#TRINAXAI_PROXY_SECRET_FILE=./storage/.proxy_secret
#TRINAXAI_PROXY_SECRET=
# Comma-separated transport peers allowed to present the HMAC proxy identity.
# Keep empty for native loopback-only mode; Docker Compose sets its own narrow subnet.
#TRINAXAI_PROXY_TRUSTED_PEERS=
# Requests per minute allowed through the narrow Ollama PWA facade.
#TRINAXAI_OLLAMA_PROXY_RATE_LIMIT=30
# Backend token-bucket capacity and refill interval, per verified IP/bucket.
#TRINAXAI_RATE_LIMIT_PER_MINUTE=30
#TRINAXAI_RATE_LIMIT_WINDOW_SECONDS=60

# HTTP agent workspaces must live below one of these platform-path-separated
# roots. Remote yolo remains disabled; if explicitly enabled, it is localhost-only.
#TRINAXAI_AGENT_WORKSPACE_ROOTS=~/Documents/projects
#TRINAXAI_AGENT_HTTP_YOLO=0
# Maximum wall time and no-activity time for one Agent run.
#TRINAXAI_AGENT_TIMEOUT=600
#TRINAXAI_AGENT_STALL_TIMEOUT=120
# Linux terminal execution uses bubblewrap and no network. Other platforms fail
# closed unless this explicit, high-risk compatibility escape hatch is enabled.
#TRINAXAI_AGENT_ALLOW_UNSANDBOXED_COMMANDS=0

# ── GPU & Quantization ─────────────────────────────────────────────────────
# GPU layers to offload (Ollama native). Empty = auto.
#OLLAMA_NUM_GPU=
# Aggressive Q4_K_M-style quantization profile (1 = on).
#TRINAXAI_AGGRESSIVE_QUANT=0

# ── OCR (scanned PDFs) ─────────────────────────────────────────────────────
# Enable Tesseract OCR. Requires the tesseract system package.
#TRINAXAI_OCR=0

# ── PWA / Vite (frontend build-time) ───────────────────────────────────────
TRINAXAI_FRONTEND_URL=https://localhost:3334
TRINAXAI_FRONTEND_MODE=preview
TRINAXAI_RAG_TARGET=https://127.0.0.1:3333
VITE_TRINAXAI_RAG_TARGET=https://127.0.0.1:3333
VITE_TRINAXAI_RAG_BASE=/api/rag
VITE_TRINAXAI_OLLAMA_BASE=/api/ollama
VITE_TRINAXAI_DEV_RAG_BASE=/api/rag
VITE_TRINAXAI_DEV_OLLAMA_BASE=/api/ollama
VITE_TRINAXAI_INDEX_DIR=~/Documents
VITE_TRINAXAI_REPO_URL=https://github.com/TrinaxCode/TrinaxAI
VITE_TRINAXAI_DOCS_URL=https://github.com/TrinaxCode/TrinaxAI#readme
VITE_TRINAXAI_VISION_MODEL=qwen3.5:4b

# ── Optional local STT (`pip install -e '.[voice]'`) ─────────────────────────────
#TRINAXAI_VOICE_DEVICE=auto
#TRINAXAI_VOICE_COMPUTE_TYPE=default

# ── Backup consistency ─────────────────────────────────────────────────────────
# Pause the API around a backup so app state/attachments stop mutating. The
# archive also takes the shared index lock. Disable only for an operator-managed
# quiescent snapshot.
#TRINAXAI_BACKUP_QUIESCE=1
